{
  "name": "bachata-co-kr",
  "version": "0.2.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "audit:copy": "node scripts/audit-public-copy.mjs",
    "audit:community": "node scripts/audit-community-public-html.mjs",
    "audit:seo": "node scripts/audit-seo-runtime.mjs",
    "legacy:redirects": "node scripts/write-legacy-redirects.mjs",
    "verify": "npm run typecheck && npm run build && npm run audit:copy && npm run audit:community",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "verify:cloudflare": "npm run verify && npm run cf:build"
  },
  "dependencies": {
    "lucide-react": "1.23.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "1.20.1",
    "@playwright/test": "1.61.1",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "6.0.3",
    "wrangler": "4.108.0"
  },
  "overrides": {
    "postcss": "8.5.16"
  }
}
